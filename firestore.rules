rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, role, displayName, photoURL, telegramId, address, phone, rating, isOnline, skills, limitations, schedule
    //
    // Collection: orders
    // Fields: id, clientId, cleanerId, type, tasks, status, dateTime, isAsap, price, address, commission, payout, createdAt, updatedAt
    //
    // Collection: chats
    // Fields: id, orderId, participants, lastMessage, updatedAt
    //
    // Collection: chats/{chatId}/messages
    // Fields: id, chatId, senderId, text, timestamp
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "DavydoffMikhail.S@gmail.com" ||
         request.auth.token.email == "admin@admin.ru" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator'));
    }

    function isParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'displayName']) &&
             data.uid is string &&
             data.role in ['client', 'cleaner', 'operator'] &&
             data.displayName is string && data.displayName.size() < 100;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['clientId', 'type', 'status', 'dateTime', 'price', 'address']) &&
             data.clientId is string &&
             data.type in ['cleaning', 'help'] &&
             data.status in ['created', 'searching', 'in_dialog', 'awaiting_payment', 'paid', 'completed', 'cancelled'] &&
             data.price is number && data.price >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role != 'operator' || isAdmin());
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /payoutRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.cleanerId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.cleanerId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.cleanerId || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isParticipant(chatId) || isAdmin());
        allow create: if isAuthenticated() && isParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
